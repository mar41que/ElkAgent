{
  "Agent": {
    "OutputMode": "elasticsearch",
    "Elasticsearch": {
      "Url": "http://localhost:9200",
      "IndexPrefix": "elkagent",
      "Username": "",
      "Password": "",
      "BulkSize": 100,
      "FlushIntervalMs": 5000
    },
    "Logstash": {
      "Host": "localhost",
      "Port": 5044,
      "Protocol": "http"
    },
    "Collectors": {
      "WindowsEvent": {
        "Enabled": true,
        "Channels": [ "System", "Application", "Security" ],
        "PollIntervalMs": 5000
      },
      "File": {
        "Enabled": false,
        "Paths": [ "C:\\Logs\\app.log" ],
        "PollIntervalMs": 2000
      },
      "Syslog": {
        "Enabled": false,
        "Port": 514
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}